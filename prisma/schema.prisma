generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  phone           String?
  passwordHash    String?
  role            Role           @default(USER)
  isOrganizer     Boolean        @default(false)
  college         String?
  graduationYear  Int?
  currentRole     String?
  dateOfBirth     DateTime?
  bio             String?
  profileImage    String?
  status          UserStatus     @default(ACTIVE)
  isEmailVerified Boolean        @default(false)
  googleId        String?        @unique
  internshipInterest Boolean?
  internshipDomains  String[]
  interests          String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  announcements   Announcement[]
  auditLogs       AuditLog[]
  bookmarks       Bookmark[]
  certificates    Certificate[]
  organizedEvents Event[]        @relation("OrganizerEvents")
  galleryImages   GalleryImage[]
  registrations   Registration[]
  socialLinks     SocialLink?
  skills          UserSkill[]
  referrals       Referral[]
  referralClicks  ReferralClick[]
  notifications   Notification[]

  @@index([email])
  @@index([status])
}

model SocialLink {
  id        String  @id @default(uuid())
  userId    String  @unique
  linkedin  String?
  github    String?
  instagram String?
  twitter   String?
  website   String?
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSkill {
  id     String @id @default(uuid())
  userId String
  skill  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill])
}

model GalleryImage {
  id        String   @id @default(uuid())
  userId    String
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id                   String         @id @default(uuid())
  slug                 String?        @unique
  title                String
  subtitle             String?
  category             EventCategory
  theme                String?
  organizerId          String
  mode                 EventMode      @default(ONLINE)
  venueName            String?
  address              String?
  mapLink              String?
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime
  bannerImage          String?
  eventPoster          String?
  description          String
  prizeType            PrizeType      @default(NONE)
  prizeAmount          Float?
  maxParticipants      Int?
  approvalMode         ApprovalMode   @default(AUTO)
  status               EventStatus    @default(DRAFT)
  isPaid               Boolean        @default(false)
  registrationType     RegistrationType @default(INDIVIDUAL)
  minTeamSize          Int?
  maxTeamSize          Int?
  ticketPrice          Float?
  paymentType          PaymentType    @default(FREE)
  upiId                String?
  upiQrCode            String?
  primaryColor         String?
  secondaryColor       String?
  accentColor          String?
  customFormFields     Json?
  rejectionReason      String?
  isFeatured           Boolean        @default(false)
  isPremium            Boolean        @default(false)
  showOnLanding        Boolean        @default(false)
  displayOrder         Int            @default(0)
  requiresLinkedinShare    Boolean        @default(false)
  linkedinShareDescription String?
  linkedinSharePoster      String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?
  announcements        Announcement[]
  bookmarks            Bookmark[]
  certificates         Certificate[]
  organizer            User           @relation("OrganizerEvents", fields: [organizerId], references: [id])
  faqs                 FAQ[]
  registrations        Registration[]
  referrals            Referral[]

  @@index([status])
  @@index([category])
  @@index([organizerId])
  @@index([startDate])
}

model Registration {
  id            String             @id @default(uuid())
  eventId       String
  userId        String
  referralId    String?            // Event-level referral tracking
  status        RegistrationStatus @default(PENDING)
  paymentStatus PaymentStatus      @default(UNPAID)
  formData      Json?
  paymentRef    String?
  paymentProof  String?
  registeredAt  DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  event         Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  referral      Referral?          @relation(fields: [referralId], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@index([status])
  @@index([eventId])
  @@index([userId])
}

model Referral {
  id          String   @id @default(uuid())
  code        String   @unique
  eventId     String
  referrerId  String?
  college     String?

  clicks      Int      @default(0)
  conversions Int      @default(0)

  createdAt   DateTime @default(now())

  event       Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  referrer    User?           @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  clicksData  ReferralClick[]
  registrations Registration[]
}

model ReferralClick {
  id          String   @id @default(uuid())
  referralId  String
  ip          String?
  userAgent   String?
  userId      String?

  createdAt   DateTime @default(now())

  referral    Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Announcement {
  id          String   @id @default(uuid())
  eventId     String
  title       String
  content     String
  publishDate DateTime @default(now())
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation(fields: [createdBy], references: [id])
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model FAQ {
  id        String   @id @default(uuid())
  eventId   String
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Certificate {
  id             String   @id @default(uuid())
  userId         String
  eventId        String
  certificateUrl String
  issuedAt       DateTime @default(now())
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum EventCategory {
  Hackathon
  Ideathon
  Webinar
  Techfest
  Other
}

enum EventMode {
  ONLINE
  OFFLINE
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  COMPLETED
}

enum ApprovalMode {
  AUTO
  MANUAL
}

enum PrizeType {
  NONE
  CASH
  MERCH
  POINTS
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  PAYMENT_PENDING
  ATTENDED
}

enum RegistrationType {
  INDIVIDUAL
  GROUP
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum PaymentType {
  FREE
  MANUAL_UPI
  RAZORPAY
}

model HeroSlide {
  id        String   @id @default(uuid())
  imageUrl  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model CommunityShowcaseImage {
  id        String   @id @default(uuid())
  imageUrl  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String
  quote     String
  avatarUrl String?
  badge     String?
  link      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model HomepageSection {
  id        String   @id @default(uuid())
  key       String   @unique
  title     String
  order     Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  entityId  String?          // e.g. eventId, registrationId
  entityType String?         // e.g. "Event", "Registration"
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

enum NotificationType {
  EVENT_APPROVED
  EVENT_REJECTED
  REGISTRATION_CONFIRMED
  REGISTRATION_APPROVED
  REGISTRATION_REJECTED
  EVENT_UPDATED
  EVENT_CANCELLED
  ANNOUNCEMENT
  CERTIFICATE_ISSUED
  GENERAL
}
