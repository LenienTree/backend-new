NODE_ENV=development
PORT=5000

# Database — Supabase (recommended free tier)
# Pooler URL: port 6543, used at runtime (60 concurrent connections via PgBouncer)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"
# Direct URL: port 5432, used only for migrations (prisma migrate deploy)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# Database — Neon (alternative)
# DATABASE_URL="postgresql://neondb_owner:password@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://neondb_owner:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# JWT
JWT_SECRET=88175a9552b404e167647c8d0a9c54ab29359182460e16ac81274e1556304852
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=f7e60f58b153e805cd320f5dd33b30e4af728de407a5f3e879b6b702b25ddf28
JWT_REFRESH_EXPIRES_IN=30d

# AWS S3 Storage
S3_BUCKET_NAME=your_bucket_name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="LenientTree <no-reply@lenienttree.com>"

# Frontend
CLIENT_URL=http://localhost:3000

# Rate Limiting (global: 60 req/min per IP; auth routes have their own stricter limits)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Node.js thread pool — set in OS env or PM2 config BEFORE node starts, not here
# UV_THREADPOOL_SIZE=16

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
